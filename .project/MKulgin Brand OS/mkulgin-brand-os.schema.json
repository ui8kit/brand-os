        "explanatory",
        "editorial-or-conversational"
      ],
      "principle": "Explain, don't sell. Show how it works, where the risks are, what worked, what turned out to be noise.",
      "avoid": [
        "marketing jargon",
        "motivational fluff",
        "AI hype language",
        "empty thought-leadership phrases",
        "fake certainty without evidence"
      ]
