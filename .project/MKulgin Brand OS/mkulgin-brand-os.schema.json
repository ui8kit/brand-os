  "designGrammar": {
    "styleDirection": "baltic-tech-editorial",
    "networkOperatorMotifs": [
      "network-routes-and-nodes",
      "index-markers-and-route-labels",
      "topology-lines-and-graphs",
      "catalog-structures-and-card-grids",
      "signal-markers-and-technical-dividers",
      "monospace-labels-for-ids-dates-metrics"
    ],
    "accentRule": "Amber/copper is the human warmth inside a strict system. Never use on large solid surfaces — only as strokes: borders, small labels, quote-bar left of text, chart markers, grants highlights.",
    "photoModes": {
      "editorial": "Monochrome portrait, graphite + amber line accents, clean editorial crop",
      "community": "Warm environmental photos, natural color, orange/copper accents in surroundings"
    },
    "densityModes": {
      "landing": "comfortable",
      "tech-blog": "relaxed",
      "article-detail": "relaxed",
      "about": "comfortable",
      "library": "comfortable",
      "projects": "comfortable",
      "media": "comfortable",
      "newsletter": "comfortable",
      "community": "comfortable",
      "catalog": "comfortable",
      "grants": "relaxed",
      "events": "comfortable",
      "archive": "relaxed"
    },
    "shapeLanguage": {
      "core": "Paper-like backgrounds, steel blue structural accents, restrained copper highlights, calm editorial typography, mono evidence fragments, and low-noise layouts with clear hierarchy. Network routes, index markers, and warm amber signal as the signature motif."
    },
    "surfaceLanguage": {
      "base": "Surfaces should read like an engineering journal or operator notebook, not a startup landing page or flashy creator site.",
      "depthRule": "Use depth sparingly through paper layers, quote callouts, and evidence cards; avoid aggressive shadows and glossy gradients.",
      "accentRule": "Baltic blue carries structure and actions. Warm amber/copper appears only as strokes: quote-bar, small labels, grants badges, chart markers — never on large solid planes.",
      "contrastRule": "Long-form reading should stay soft but legible, with dark graphite text on warm paper backgrounds and clear blue link affordances."
    },
    "imageTreatment": {
      "style": "Documentary portraits, book covers, screenshots of real dashboards or graphs, simple charts, and quiet editorial crops.",
      "preferred": [
        "black-and-white portrait crops",
        "warm environmental portraits",
        "book covers and scans",
        "simple revenue or growth charts",
        "annotated screenshots"
      ],
      "avoid": [
        "stock startup teams",
        "shiny 3D illustrations",
        "generic SaaS hero renders",
        "neon gradients",
        "overprocessed cinematic lighting"
      ]
    },
    "contentVoice": {
      "adjectives": [
        "honest",
        "practical",
        "experienced",
        "skeptical",
        "human",
        "measured"
      ],
      "avoid": [
        "guru language",
        "visionary cliches",
        "thought leadership filler",
        "fake disruption rhetoric",
        "pretending failure does not exist"
      ]
    }
  },
