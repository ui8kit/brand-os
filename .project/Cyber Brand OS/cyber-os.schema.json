  "designGrammar": {
    "styleDirection": "dark-tech-cinematic",
    "densityModes": {
      "landing": "comfortable",
      "dashboard": "compact",
      "docs": "comfortable",
      "admin": "compact",
      "sms": "compact",
      "user-management": "compact",
      "login-auth": "comfortable",
      "webapp": "compact",
      "spa": "compact",
      "mpa": "comfortable",
      "tech-blog": "relaxed"
    },
    "shapeLanguage": {
      "core": "Dark navy shells, precise indigo accents, restrained glass panels, compact controls, and bottom-anchored feature cards with cinematic image overlays."
    },
    "surfaceLanguage": {
      "base": "Public surfaces can use cinematic gradients and glass panels, while operational surfaces stay flatter, denser, and more system-like.",
      "depthRule": "Use blur and elevated shadows mainly for navigation, overlays, and landing highlights; keep admin and data tables flatter.",
      "accentRule": "Indigo is the primary action accent, but keep most surfaces neutral so charts, status chips, and CTA gradients stand out.",
      "contrastRule": "Maintain strong text contrast on dark shells and reserve pure white for headings, CTAs, and mono highlights."
    },
    "imageTreatment": {
      "style": "Product screenshots, dashboards, code snippets, and operator workflows with dark gradient fades at the bottom.",
      "preferred": [
        "full-bleed product imagery",
        "cropped dashboard screenshots",
        "dark screenshots with indigo highlights",
        "subtle grain or blur on backgrounds"
      ],
      "avoid": [
        "bright stock photography",
        "cartoon illustrations",
        "overexposed screenshots",
        "rainbow cyberpunk effects"
      ]
    },
    "contentVoice": {
      "adjectives": [
        "clear",
        "credible",
        "fast",
        "technical",
        "operator-friendly",
        "composed"
      ],
      "avoid": [
        "confusing jargon",
        "buzzword-heavy AI copy",
        "cute microcopy on admin surfaces",
        "marketing slogans in data tables"
      ]
    }
  },
  "componentPolicy": {
    "keepStandard": [
      "Accordion",
      "Badge",
      "Field",
      "Grid",
      "Icon",
      "Image",
      "Stack",
      "Text",
      "Title"
    ],
    "wrapEarly": [
      "Button",
      "Card",
      "Container",
      "Group",
      "Sheet"
    ],
    "customBlocks": [
      "CyberHeader",
      "CyberFooter",
      "CyberSidebar",
      "HeroBlock",
      "FeatureSplitBlock",
      "FeatureCardGridBlock",
      "DataTableBlock",
      "JsonEditorBlock",
      "TokenShowcaseBlock",
      "ComponentGalleryBlock"
    ],
    "rawHtmlAllowedFor": [
      "embedded charts",
      "syntax-highlighted code",
      "third-party status widgets"
    ],
    "avoid": [
      "oversized rounded pills on enterprise surfaces",
      "default card styling without Cyber overlay on landing pages",
      "heavy gradients on CRUD and docs surfaces",
      "using decorative glass effects on dense tables",
      "mixing too many accent colors in a single screen"
    ]
  },
  "recipes": {
    "pageArchetypes": {
      "landing": {
        "purpose": "Introduce Cyber OS as a central data hub and convert technical visitors into trying the product or exploring docs.",
        "requiredSections": [
          "hero",
          "logo-banner",
          "feature-split",
          "feature-card-grid",
          "testimonials",
          "cta"
        ]
      },
      "dashboard": {
        "purpose": "Give operators an at-a-glance overview of ingest volume, recent activity, health, and shortcuts.",
        "requiredSections": [
          "stats-overview",
          "charts",
          "recent-activity",
          "quick-actions"
        ]
      },
      "docs": {
        "purpose": "Document data flows, component rules, and brand usage with a clear reading structure and fast navigation.",
        "requiredSections": [
          "docs-hero",
          "sidebar-nav",
          "content",
          "toc",
          "prev-next"
        ]
      },
      "admin": {
        "purpose": "Manage collections, records, permissions, and workflows from a stable left-sidebar CRUD shell.",
        "requiredSections": [
          "admin-sidebar",
          "data-table",
          "detail-panel",
          "crud-form",
          "activity-feed"
        ]
      },
      "sms": {
        "purpose": "Operate message-based automations and communication history in a compact, chat-oriented workspace.",
        "requiredSections": [
          "chat-shell",
          "message-stream",
          "composer",
          "contact-sidebar"
        ]
      },
      "user-management": {
        "purpose": "Review users, roles, invitations, and account health with table-first clarity.",
        "requiredSections": [
          "user-stats",
          "filters",
          "user-table",
          "role-panel"
        ]
      },
      "login-auth": {
        "purpose": "Authenticate users with a focused, trust-heavy entry point and minimal friction.",
        "requiredSections": [
          "auth-hero",
          "auth-panel",
          "trust-strip"
        ]
      },
      "webapp": {
        "purpose": "Present the main product workspace with command-driven navigation, data tables, and contextual detail panels.",
        "requiredSections": [
          "workspace-shell",
          "command-bar",
          "data-table",
          "detail-panel"
        ]
      },
      "spa": {
        "purpose": "Support fast route changes and stateful workflows inside a single-page application shell.",
        "requiredSections": [
          "workspace-shell",
          "command-bar",
          "route-view",
          "inspector-panel"
        ]
      },
      "mpa": {
        "purpose": "Support a multipage marketing and resource site with strong hierarchy and repeatable shell patterns.",
        "requiredSections": [
          "page-header",
          "content-grid",
          "resource-band",
          "footer-links"
        ]
      },
      "tech-blog": {
        "purpose": "Publish technical stories, release notes, and deep product explainers with editorial rhythm.",
        "requiredSections": [
          "blog-hero",
          "featured-article",
          "article-list",
          "newsletter",
          "footer-links"
        ]
      }
    },
    "sectionArchetypes": {
      "hero": {
        "purpose": "Launch-oriented hero with compact CTAs, gradient title treatment, and strong dark shell contrast.",
        "requiredSlots": ["eyebrow", "title", "subtitle", "primary-cta", "secondary-cta", "hero-visual"],
        "fixedTraits": ["above-fold", "dark-shell", "tight-heading", "indigo-accent"]
      },
      "logo-banner": {
        "purpose": "Show trust logos in a horizontally scrolling or repeated strip.",
        "requiredSlots": ["intro", "logo-list"],
        "fixedTraits": ["marquee-friendly", "muted", "separator-fade"]
      },
      "feature-split": {
        "purpose": "Pair a screenshot or visual with supporting text in alternating left-right sections.",
        "requiredSlots": ["image", "title", "body", "meta-points"],
        "fixedTraits": ["two-column", "alternating", "landing-only"]
      },
      "feature-card-grid": {
        "purpose": "Display fixed-height feature cards with image overlays and bottom-anchored copy.",
        "requiredSlots": ["background-image", "title", "body"],
        "fixedTraits": ["rounded-xl", "h-350", "bottom-anchored", "glass-border"]
      },
      "testimonials": {
        "purpose": "Build credibility using customer quotes, logos, or analyst statements.",
        "requiredSlots": ["quote", "source"],
        "fixedTraits": ["muted", "brand-consistent"]
      },
      "cta": {
        "purpose": "Close a public surface with one clear conversion action.",
        "requiredSlots": ["headline", "supporting-copy", "button"],
        "fixedTraits": ["single-primary-action", "high-contrast", "gradient-cta"]
      },
      "stats-overview": {
        "purpose": "Expose key metrics in compact cards with clear trend indicators.",
        "requiredSlots": ["metric-value", "metric-label", "trend", "status"],
        "fixedTraits": ["compact", "card-grid", "quick-scan"]
      },
      "charts": {
        "purpose": "Show time-series or categorical data with restrained chart colors and operator clarity.",
        "requiredSlots": ["chart", "legend", "range-controls"],
        "fixedTraits": ["dark-surface", "muted-frame", "chart-palette"]
      },
      "recent-activity": {
        "purpose": "List recent ingests, mutations, errors, and operator actions in chronological order.",
        "requiredSlots": ["event-list", "timestamp", "event-meta"],
        "fixedTraits": ["timeline", "compact", "mono-meta"]
      },
      "quick-actions": {
        "purpose": "Provide high-frequency shortcuts near the top of operational surfaces.",
        "requiredSlots": ["actions"],
        "fixedTraits": ["compact", "button-group", "operator-first"]
      },
      "docs-hero": {
        "purpose": "Introduce docs sections and orient the reader before the main content area.",
        "requiredSlots": ["eyebrow", "title", "summary"],
        "fixedTraits": ["readable-width", "muted-meta", "no-heavy-effects"]
      },
      "sidebar-nav": {
        "purpose": "Provide a left navigation rail for docs or app surfaces.",
        "requiredSlots": ["section-list", "active-state"],
        "fixedTraits": ["left-rail", "compact", "sticky-allowed"]
      },
      "content": {
        "purpose": "Main reading or data presentation column.",
        "requiredSlots": ["body"],
        "fixedTraits": ["semantic", "scannable"]
      },
      "toc": {
        "purpose": "Show headings and anchor links for long-form content.",
        "requiredSlots": ["anchors"],
        "fixedTraits": ["right-rail", "small-type"]
      },
      "prev-next": {
        "purpose": "Link adjacent docs or resource pages.",
        "requiredSlots": ["previous-link", "next-link"],
        "fixedTraits": ["footer-nav", "directional"]
      },
      "admin-sidebar": {
        "purpose": "Primary navigation for CRUD, settings, collections, and documentation links.",
        "requiredSlots": ["logo", "primary-nav", "secondary-nav"],
        "fixedTraits": ["left-sidebar", "compact", "surface-subtle"]
      },
      "data-table": {
        "purpose": "Show records with sorting, filtering, row actions, and selection states.",
        "requiredSlots": ["columns", "rows", "filters", "pagination"],
        "fixedTraits": ["dense", "row-actions", "sticky-header"]
      },
      "detail-panel": {
        "purpose": "Reveal focused record details or contextual metadata next to a table.",
        "requiredSlots": ["title", "meta", "actions"],
        "fixedTraits": ["side-panel", "contextual", "surface-elevated"]
      },
      "crud-form": {
        "purpose": "Create or edit structured data with clear grouping and validation.",
        "requiredSlots": ["fields", "validation", "submit-actions"],
        "fixedTraits": ["stacked", "grouped-sections", "system-first"]
      },
      "activity-feed": {
        "purpose": "Track changes, audit events, and operational history.",
        "requiredSlots": ["event-list", "user", "timestamp"],
        "fixedTraits": ["muted", "audit-friendly", "compact"]
      },
      "chat-shell": {
        "purpose": "Host message-driven workflows for SMS or assistant operations.",
        "requiredSlots": ["conversation-list", "active-thread"],
        "fixedTraits": ["split-view", "compact", "operator-first"]
      },
      "message-stream": {
        "purpose": "Render chronological inbound and outbound messages.",
        "requiredSlots": ["messages", "timestamps", "delivery-state"],
        "fixedTraits": ["bubble-lite", "mono-meta", "dense"]
      },
      "composer": {
        "purpose": "Compose outbound messages or automation commands.",
        "requiredSlots": ["input", "attachments", "send-action"],
        "fixedTraits": ["sticky-bottom", "compact", "clear-primary-action"]
      },
      "contact-sidebar": {
        "purpose": "Show contact metadata, tags, and message history shortcuts.",
        "requiredSlots": ["contact-meta", "tags", "actions"],
        "fixedTraits": ["side-panel", "compact"]
      },
      "user-stats": {
        "purpose": "Summarize account counts, role health, and invitation status.",
        "requiredSlots": ["metric-cards"],
        "fixedTraits": ["compact", "row-friendly"]
      },
      "filters": {
        "purpose": "Filter and segment datasets without hiding the query state.",
        "requiredSlots": ["search", "selects", "chips"],
        "fixedTraits": ["toolbar", "compact", "clear-active-state"]
      },
      "user-table": {
        "purpose": "List users, roles, access status, and quick actions.",
        "requiredSlots": ["rows", "role-badge", "status", "actions"],
        "fixedTraits": ["data-table-derived", "badge-heavy", "compact"]
      },
      "role-panel": {
        "purpose": "Explain and edit role scopes, permissions, and inheritance.",
        "requiredSlots": ["role-summary", "permissions", "save-action"],
        "fixedTraits": ["surface-elevated", "detail-panel"]
      },
      "auth-hero": {
        "purpose": "Establish trust and product context on login or signup screens.",
        "requiredSlots": ["title", "summary", "supporting-proof"],
        "fixedTraits": ["minimal", "trust-focused", "dark-shell"]
      },
      "auth-panel": {
        "purpose": "Hold the actual authentication form in a focused card.",
        "requiredSlots": ["fields", "submit", "secondary-links"],
        "fixedTraits": ["centered", "card", "simple"]
      },
      "trust-strip": {
        "purpose": "Reinforce trust with security, compliance, or customer proof near auth forms.",
        "requiredSlots": ["items"],
        "fixedTraits": ["small-type", "muted", "horizontal"]
      },
      "workspace-shell": {
        "purpose": "Establish the primary app shell for webapp and SPA surfaces.",
        "requiredSlots": ["topbar", "sidebar", "content"],
        "fixedTraits": ["application-shell", "persistent-nav"]
      },
      "command-bar": {
